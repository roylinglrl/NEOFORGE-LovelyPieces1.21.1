  "item.lovely_sparkle_pieces.lucy_axe": "Lucy Axe",
  "item.lovely_sparkle_pieces.lucy_axe.message.0": "\uD83E\uDE93 These trees are square!",
  "item.lovely_sparkle_pieces.lucy_axe.message.1": "\uD83E\uDE93 Are they segmented?!",
  "item.lovely_sparkle_pieces.lucy_axe.message.10": "\uD83E\uDE93 Nice weather today!",
  "item.lovely_sparkle_pieces.lucy_axe.message.11": "\uD83E\uDE93 Die! Die!",
  "item.lovely_sparkle_pieces.lucy_axe.message.12": "\uD83E\uDE93 Chop! Chop!",
  "item.lovely_sparkle_pieces.lucy_axe.message.13": "\uD83E\uDE93 Destroy!",
  "item.lovely_sparkle_pieces.lucy_axe.message.14": "\uD83E\uDE93 Chop!",
  "item.lovely_sparkle_pieces.lucy_axe.message.15": "\uD83E\uDE93 Awesome!",
  "item.lovely_sparkle_pieces.lucy_axe.message.16": "\uD83E\uDE93 All trees must die!",
  "item.lovely_sparkle_pieces.lucy_axe.message.17": "\uD83E\uDE93 Again! Let's chop another one!",
  "item.lovely_sparkle_pieces.lucy_axe.message.18": "\uD83E\uDE93 A fine chop!",
  "item.lovely_sparkle_pieces.lucy_axe.message.19": "\uD83E\uDE93 Too easy!",
  "item.lovely_sparkle_pieces.lucy_axe.message.2": "\uD83E\uDE93 Stupid trees!",
  "item.lovely_sparkle_pieces.lucy_axe.message.3": "\uD83E\uDE93 Hohoho!",
  "item.lovely_sparkle_pieces.lucy_axe.message.4": "\uD83E\uDE93 Done!",
  "item.lovely_sparkle_pieces.lucy_axe.message.5": "\uD83E\uDE93 I feel invigorated!",
  "item.lovely_sparkle_pieces.lucy_axe.message.6": "\uD83E\uDE93 So fragile!",
  "item.lovely_sparkle_pieces.lucy_axe.message.7": "\uD83E\uDE93 That's it!",
  "item.lovely_sparkle_pieces.lucy_axe.message.8": "\uD83E\uDE93 Let's go chop more trees!",
  "item.lovely_sparkle_pieces.lucy_axe.message.9": "\uD83E\uDE93 Wahaha!",
  "item.lovely_sparkle_pieces.lucy_axe.message.mushroom.0": "\uD83E\uDE93 These giant mushrooms!",
  "item.lovely_sparkle_pieces.lucy_axe.message.mushroom.1": "\uD83E\uDE93 Are they trees too? How strange!",
  "item.lovely_sparkle_pieces.lucy_axe.message.mushroom.2": "\uD83E\uDE93 Doesn't matter, chop them anyway!",
  "item.lovely_sparkle_pieces.lucy_axe.message.mushroom.3": "\uD83E\uDE93 What's the deal with mushroom trees?!",
  "item.lovely_sparkle_pieces.lucy_axe.message.mushroom.4": "\uD83E\uDE93 How... did they grow so big?!",
